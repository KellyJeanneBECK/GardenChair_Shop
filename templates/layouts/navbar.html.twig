<nav class="navbar navbar-expand-lg bg-body-tertiary" data-bs-theme="dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="{{ path('app_home') }}">Garden Chair</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="{{ path('app_home') }}">Home</a>
        </li>
        {% if categories is defined %}
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Filter categories
          </a>
          <ul class="dropdown-menu">
            {% for category in categories %}
              <li><a class="dropdown-item text-secondary" href="">{{ category.name }}</a></li>
              {% for subCategory in category.subCategories %}
                <li><a class="dropdown-item" href="{{ path('app_home_product_filter', {'id': subCategory.id}) }}">{{ subCategory.name }}</a></li>
              {% endfor %}
              <li><hr class="dropdown-divider"></li>
            {% endfor %}
          </ul>
          {% endif %}
        </li>
        <li class="nav-item">
          <a class="nav-link" href="{{ path('app_cart') }}">Cart</a>
        </li>
        {% if is_granted("ROLE_ADMIN") %}
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Admin
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="{{ path('app_category') }}">Categories Manager</a></li>
            <li><a class="dropdown-item" href="{{ path('app_category_new') }}">Add new category</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{{ path('app_sub_category_index') }}">SubCategories Manager</a></li>
            <li><a class="dropdown-item" href="{{ path('app_sub_category_new') }}">Add new sub-category</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{{ path('app_user') }}">Users</a></li>
          </ul>
        </li>
        {% endif %}
        {% if is_granted("ROLE_EDITOR") %}
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Editor
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="{{ path('app_product_index') }}">Product Manager</a></li>
            <li><a class="dropdown-item" href="{{ path('app_product_new') }}">Add new product</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{{ path('app_city_index') }}">City Manager</a></li>
            <li><a class="dropdown-item" href="{{ path('app_city_new') }}">Add new city</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-secondary" href="">Orders lists</a></li>
            <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'is-completed'}) }}">Delivered</a></li>
            <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'no-delivery'}) }}">Not delivered</a></li>
            <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'pay-on-stripe-not-delivered'}) }}">Payed not delivered</a></li>
            <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'pay-on-stripe-is-delivered'}) }}">Payed delivered</a></li>
          </ul>
        </li>
        {% endif %}
        {% if app.user %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">Logout</a>
          </li>
          {% else %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_register') }}">Register</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_login') }}">Login</a>
          </li>
        {% endif %}
      </ul>
      {% if products is defined %}
      <form class="d-flex" method="get" action="{{ path('app_search_engine') }}" role="search">
        <input class="form-control me-2" type="search" name="query" placeholder="Search" aria-label="Search"/>
        <button class="btn btn-outline-success" type="submit">Search</button>
      </form>
      {% endif %}
    </div>
  </div>
</nav>
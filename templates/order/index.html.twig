{% extends 'base.html.twig' %}

{% block title %}Orders{% endblock %}

{% block body %}

<main class="container">
    <div class="row">
        <div class="col-8">
            <h1>Order</h1>
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <input type="submit" value="Continue" class="mt-4 btn btn-dark">
            {{ form_end(form) }}
        </div>
        <div class="col-4 mt-2">
            <h4>Your cart : {{ total }} $</h4>
            <p>Shipping cost :</p>
            <h3>Total :</h3>
        </div>
    </div>
</main>
<script src="https://code.jquery.com/jquery-4.0.0.min.js" integrity="sha256-OaVG6prZf4v69dPg6PhVattBXkcOWQB62pdZ3ORyrao=" crossorigin="anonymous"></script>
<script>
    $(document).ready(function(){
        const citySelector = $('#order_city');
        const cityValue = citySelector.val();

        const url = `http://localhost:8000/city/${cityValue}/shipping/cost`;

        function ajaxRequest(url) {
            $.ajax({
                url:url,
                type:'GET',
                success:function(response){
                    const newResponse = JSON.parse(response)
                    if (parseInt(newResponse.status) === 200){
                        console.log(newResponse.status)
                    }
                },
                error:function(xhr,status,error){

                }
            })
        }
    });
</script>
{% endblock %}

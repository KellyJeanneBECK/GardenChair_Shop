{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}
    <section class="container">
        <div class="card mt-4 mb-3" style="width: 100%;">
            <div class="row g-0">
                {% if product.image is not empty %}
                <div class="col-md-4">
                    <img src="{{ asset('uploads/images/'~product.image)}}" class="img-fluid rounded-start" alt="Product image">
                </div>
                {% endif %}
                <div class="col-md-8">
                    <div class="card-body">
                        <h1 class="card-title">{{ product.name }}</h1>
                        <p class="card-text">{{ product.description }}</p>
                        <h5 class="card-text">{{ product.price }}$</h5>
                        <a href="" class="btn btn-outline-dark">Add to cart</a>
                    </div>
                </div>
            </div>
        </div>
        <h2>Latest products</h2>
        <section class="d-flex justify-content-between flex-md-wrap gap-4 mt-6">
            {% for product in productList %}
            <div class="card" style="width: 18rem;">
                {% if product.image is not empty %}
                <img src="{{ asset('uploads/images/'~product.image)}}" class="card-img-top" alt="Product image">
                {% else %}
                <img src="{{ asset('img/PlaceholderProduct.jpg') }}" class="card-img-top" style="height: 300px;" alt="Product image placeholder">
                {% endif %}
                <div class="card-body">
                    <h4><a href="{{ path('app_home_product', {'id': product.id}) }}" class="card-title" style="text-decoration: none;">{{ product.name }}</a></h4>
                    <p class="card-text">{{ product.description|slice(0, 60) }} ...</p>
                    <h5 class="card-text">{{ product.price }}$</h5>
                    <a href="" class="btn btn-outline-dark">Add to cart</a>
                </div>
            </div>
            {% endfor %}
        </section>
    </section>
{% endblock %}
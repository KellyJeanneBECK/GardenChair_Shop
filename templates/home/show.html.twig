{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}
    <section class="container">
        <div class="card mt-4 mb-3" style="width: 80vw;">
            <div class="row g-0">
                {% if product.image is not empty %}
                <div class="col-md-4">
                    <img src="{{ asset('uploads/images/'~product.image)}}" class="img-fluid rounded-start" alt="Product image">
                </div>
                {% endif %}
                <div class="col-md-8">
                    <div class="card-body">
                        <h1 class="card-title">{{ product.name }}</h1>
                        <p class="card-text">{{ product.description }}</p>
                        <p class="card-text"><small class="text-body-secondary">{{ product.price }}$</small></p>
                        <a href="" class="btn btn-outline-dark">Add to cart</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
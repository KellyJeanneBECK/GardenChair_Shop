{% extends 'base.html.twig' %}

{% block title %}Hello CartController!{% endblock %}

{% block body %}

<main class="container">
    <h1>Your cart</h1>
    <table class="table table-hover">
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total price</th>
            <th>Action</th>
        </tr>
        {% for item in items %}
            <tr>
                <td>{{ item.product.name }}</td>
                <td>{{ item.product.price }} $</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.product.price * item.quantity }} $</td>
                <td>
                    <a href="" class="btn btn-outline-danger">Delete from cart</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Your cart is currently empty</td colspan="5">
            </tr>
        {% endfor %}
    </table>
    {% if items is not empty %}
        <section>
            <h2>Total</h2>
            <p class="display-6 text-success">{{ total }} $</p>
            <a href="" class="btn btn-dark">Confirm cart</a>
            <a href="" class="btn btn-danger">Delete cart</a>
        </section>
    {% endif %}
</main>
{% endblock %}

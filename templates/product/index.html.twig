{% extends 'base.html.twig' %}

{% block title %}Product Manager{% endblock %}

{% block body %}
    <section class="container">
        <h1>Product Manager</h1>

        {% include 'layouts/_flash_message.html.twig' %}

        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.name }}</td>
                    <td>{{ product.description|slice(0, 60) }} ...</td>
                    <td>{{ product.price }}</td>
                    <td>{{ product.stock }}</td>
                    <td>
                        <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-outline-primary">show</a>
                        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-outline-success">edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">no records found</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <a href="{{ path('app_product_new') }}" class="btn btn-primary">Create new</a>
    </section>
{% endblock %}
